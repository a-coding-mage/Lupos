# Lupos tinyconfig base.
#
# Mirrors Linux's scripts/kconfig tinyconfig flow: this file is supplied via
# KCONFIG_ALLCONFIG while running --allnoconfig so only unavoidable symbols
# and explicitly-listed bring-up switches survive.

CONFIG_LUPOS=y
# CONFIG_MODULES is not set
# CONFIG_SMP is not set
# CONFIG_PCI is not set
# CONFIG_ACPI is not set
# CONFIG_SERIAL_8250 is not set
# CONFIG_FRAMEBUFFER is not set
# CONFIG_DRM is not set
# CONFIG_AGP is not set
# CONFIG_AGP_AMD64 is not set
# CONFIG_AGP_INTEL is not set
# CONFIG_DRM_I915 is not set
# CONFIG_DRM_VIRTIO_GPU is not set
# CONFIG_INPUT is not set
# CONFIG_USB is not set
# CONFIG_SOUND is not set
# CONFIG_SND_HDA_INTEL is not set
# CONFIG_VIRTIO is not set
# CONFIG_NET is not set
