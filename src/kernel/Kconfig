mainmenu "Lupos"

config LUPOS
	bool
	default y

menu "General setup"

menuconfig MODULES
	bool "Enable loadable module support"
	modules
	default y

config SMP
	bool "Symmetric multi-processing support"
	default y

config BLOCK
	bool "Enable the block layer"
	default y

endmenu

menu "Processor type and features"

config X86_64
	bool "x86-64 architecture support"
	default y

endmenu

menu "Bus support"

config PCI
	bool "PCI support"
	default y

config ACPI
	bool "ACPI support"
	default y

config IOMMU
	bool "IOMMU support"
	depends on PCI
	default n

endmenu

menu "Device Drivers"

config SERIAL_8250
	bool "8250/16550 serial port support"
	default y

config HW_RANDOM
	tristate "Hardware Random Number Generator Core support"
	default n

config NVRAM
	tristate "Non-volatile RAM support"
	default n

config CONNECTOR
	tristate "Connector - unified userspace <-> kernelspace linker"
	default n

config FRAMEBUFFER
	bool "Framebuffer console support"
	default y

config AGP
	tristate "/dev/agpgart (AGP support)"
	depends on PCI
	default m if MODULES
	default n

config AGP_AMD64
	tristate "AMD Opteron/Athlon64 on-CPU GART support"
	depends on AGP && PCI
	default m if MODULES
	default n

config AGP_INTEL
	tristate "Intel AGP chipset support"
	depends on AGP && PCI
	default m if MODULES
	default n

config DRM
	bool "Direct Rendering Manager support"
	depends on FRAMEBUFFER
	default y

config DRM_KMS_HELPER
	tristate
	depends on DRM
	default m if MODULES

config DRM_GEM_SHMEM_HELPER
	tristate
	depends on DRM
	default m if MODULES

config DRM_PANEL_ORIENTATION_QUIRKS
	tristate
	depends on DRM
	default m if MODULES

config DRM_BOCHS
	tristate "DRM Support for bochs dispi vga interface (qemu stdvga)"
	depends on DRM && PCI
	select DRM_KMS_HELPER
	select DRM_GEM_SHMEM_HELPER
	select DRM_PANEL_ORIENTATION_QUIRKS
	default m if MODULES

config DRM_I915
	tristate "Intel 915-family graphics support"
	depends on DRM && PCI
	select I2C
	select I2C_ALGOBIT
	default m if MODULES
	default n

config DRM_VIRTIO_GPU
	tristate "VirtIO GPU support"
	depends on DRM && VIRTIO && PCI
	default m if MODULES
	default n

config INPUT
	bool "Input device support"
	default y

config HID
